@startuml Pandoba_Augsburg_Use_Case

skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #41fa8e
    BorderColor #1a8a50
    FontColor #000000
    ArrowColor #1a8a50
}
skinparam actor {
    BackgroundColor #d4f5e2
    BorderColor #1a8a50
    FontColor #000000
}
skinparam packageStyle rectangle
skinparam shadowing false

' ========================
' Actors
' ========================
actor "Kunde" as Kunde
actor "Mitarbeiter" as Mitarbeiter
actor "Administrator\n(Armand)" as Admin

' ========================
' System boundary
' ========================
rectangle "Pandoba Augsburg – Website" {

    ' --- Menü ---
    package "Menü" {
        usecase "Menükarte einsehen" as UC1
        usecase "Getränkdetails aufrufen\n(Zutaten, Allergene)" as UC2
        usecase "Kategorie auswählen\n(Classic, Latte, …)" as UC3
    }

    ' --- Bestellung ---
    package "Bestellung" {
        usecase "Bestellformular ausfüllen" as UC4
        usecase "Getränk & Optionen wählen\n(Größe, Zucker, Eis, Toppings)" as UC5
        usecase "CAPTCHA lösen\n(Spam-Schutz)" as UC6
        usecase "Bestellung absenden" as UC7
        usecase "Bestellung entgegennehmen" as UC8
    }

    ' --- Standort & Kontakt ---
    package "Standort & Kontakt" {
        usecase "Standort auf Karte anzeigen" as UC9
        usecase "Öffnungszeiten einsehen" as UC10
        usecase "Kontaktinformationen abrufen" as UC11
    }

    ' --- Über Uns ---
    package "Über Uns" {
        usecase "Hintergrundgeschichte lesen" as UC12
        usecase "Kundenbewertungen lesen" as UC13
    }

    ' --- Galerie ---
    package "Galerie" {
        usecase "Bildergalerie ansehen" as UC14
    }

    ' --- Einstellungen ---
    package "Darstellung" {
        usecase "Dark / Light Mode wechseln" as UC15
    }

    ' --- Administration ---
    package "Administration" {
        usecase "Menüinhalte pflegen" as UC16
        usecase "Bewertungen verwalten" as UC17
        usecase "Website deployen" as UC18
    }
}

' ========================
' Kunde – Beziehungen
' ========================
Kunde --> UC1
Kunde --> UC3
UC1 .> UC2 : <<include>>
UC3 .> UC1 : <<include>>

Kunde --> UC4
UC4 .> UC5 : <<include>>
UC4 .> UC6 : <<include>>
UC4 .> UC7 : <<include>>

Kunde --> UC9
Kunde --> UC10
Kunde --> UC11
Kunde --> UC12
Kunde --> UC13
Kunde --> UC14
Kunde --> UC15

' ========================
' Mitarbeiter – Beziehungen
' ========================
Mitarbeiter --> UC8
UC7 .> UC8 : <<include>>
Mitarbeiter --> UC10

' ========================
' Admin – Beziehungen
' ========================
Admin --> UC16
Admin --> UC17
Admin --> UC18
Admin --|> Mitarbeiter

@enduml
